<% layout("/layouts/boilerplate") %>
<h1 class="col-6 offset-3"> SignUp on WanderLust</h1>
<div class="row mt-3">
    <div class="col-6 offset-3">
        <form action="/signup" method="POST" class="needs-validation" novalidate>
            <div class="mb-3">
             <lable for="username" class="form-label">Username</lable>
            <input name="username" type="text" class="form-control"id="username" required>
            <div class="valid-feedback">Looks good!</div>
            </div>
            <br> <br>
            <div class="mb-3">
            <label for="email" class="form-label">Email</label>
            <input name="email" class="form-control" id="email" type="email" required>
          </div>
         <br><br>
            <div class="mb-3">
            <label for="password" class="form-label">Password</label>
            <input name="password" class="form-control" type="password" id="password" required>
            </div>
            <br>
            <button class="btn btn-success"> Sign Up </button>
        </form>
    </div>
</div>
