<% layout("/layouts/boilerplate.ejs") %>
<body>
  <div class="container mt-4">

    <!-- Title -->
    <h3 class="text-center mb-3"><%= listing.title %></h3>

    <!-- Listing Card -->
    <div class="card col-md-6 offset-md-3 listing-card mb-4">
      <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing_image">
      <div class="card-body">
        <p class="mb-1"><strong>Owned by:</strong> <i><%= listing.owner.username %></i></p>
        <p class="mb-1"><%= listing.description %></p>
        <p class="mb-1"><strong>₹</strong><%= listing.price %></p>
        <p class="mb-1"><%= listing.country %></p>
        <p class="mb-1"><%= listing.location %></p>
      </div>
    </div>

    <!-- Edit / Delete Buttons -->
    <% if (currUser && listing.owner._id.equals(currUser._id)) { %>
    <div class="text-center mb-4">
      <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark me-2">Edit</a>

      <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="d-inline">
        <button class="btn btn-danger">Delete</button>
      </form>
    </div>
    <% } %>

    <hr>
    <!-- REVIEW SECTION -->
    <% if(currUser) { %>
    <div class="col-md-8 offset-md-2">
      <h4 class="text-center mb-3">Leave a Review</h4>

      <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation mb-4">
      <div class="mb-3 mt-3">
        <label class="form-label">Rating</label>
        <fieldset class="starability-slot mb-3">
          <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" checked />
          <input type="radio" id="rate1" name="review[rating]" value="1" />
          <label for="rate1" title="Terrible">1 star</label>
          <input type="radio" id="rate2" name="review[rating]" value="2" />
          <label for="rate2" title="Not good">2 stars</label>
          <input type="radio" id="rate3" name="review[rating]" value="3" />
          <label for="rate3" title="Average">3 stars</label>
          <input type="radio" id="rate4" name="review[rating]" value="4" />
          <label for="rate4" title="Very good">4 stars</label>
          <input type="radio" id="rate5" name="review[rating]" value="5" />
          <label for="rate5" title="Amazing">5 stars</label>
        </fieldset>

        <label class="form-label">Comments</label>
        <textarea name="review[comment]" class="form-control mb-3" rows="4" required></textarea>
        <div class="invalid-feedback">Please add a comment.</div>

        <div class="text-center">
          <button class="btn btn-outline-dark">Submit</button>
        </div>
      </form>
    </div>
    <% } %>

    <!-- All Reviews -->
    <h4 class="text-center mb-3"><b>All Reviews</b></h4>

    <div class="row justify-content-center">
  <% for (let review of listing.reviews) { %>
    <div class="card col-md-5 mb-4">
      
      <div class="card-body d-flex flex-column">

        <!-- username -->
        <h5 class="card-title">@<%= review.author.username %></h5>

        <!-- comment -->
        <p class="card-text"><%= review.comment %></p>

        <!-- rating -->
        <p class="starability-result mb-3" data-rating="<%= review.rating %>">
          Rated: <%= review.rating %> stars
        </p>

        <!-- DELETE BUTTON (left side + black) -->
        <% if (currUser && review.author._id.equals(currUser._id)) { %>
          <form method="POST"
                action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                class="mt-auto text-start">
            <button class="btn btn-sm btn-dark">
              Delete
            </button>
          </form>
        <% } %>

      </div>

    </div>
  <% } %>
</div>


  </div>
</body>
